{
  "name": "finapp",
  "productName": "finapp",
  "version": "1.0.2",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm:dev:backend\" \"npm:dev:electron\"",
    "dev:backend": "backend\\venv\\Scripts\\python.exe -m uvicorn backend.fastapi_app:app --reload --reload-exclude data.json --reload-exclude cagr_data.json --reload-exclude thresholds.json --port 8000",
    "dev:electron": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "azeroth",
    "email": "rakhathrd1314@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "concurrently": "^9.2.1",
    "electron": "41.0.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "electron-squirrel-startup": "^1.0.1",
    "tailwindcss": "^4.2.2"
  }
}